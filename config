[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/zehra0055/Odev-Teslim-Portal-.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[credential]
	helper = manager-core
[branch "main"]
	remote = origin
	merge = refs/heads/main
